# eBay API Credentials
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=http://localhost:3000/api/ebay/auth
EBAY_SANDBOX=true

# AI Provider (optional - set ONE of the following)

# Option 1: Anthropic Claude
ANTHROPIC_API_KEY=

# Option 2a: Google Vertex AI with ADC (run: gcloud auth application-default login)
GOOGLE_CLOUD_PROJECT=your-project-id

# Option 2b: Google Vertex AI with service account JSON (alternative to 2a)
# GOOGLE_VERTEX_CREDENTIALS={"type":"service_account","project_id":"..."}

# Option 3: OpenAI
OPENAI_API_KEY=
